esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules/@expo/apple-utils/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules/@expo/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules/@expo/apple-utils/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules/@expo/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/@expo+apple-utils@2.1.22/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../@expo+apple-utils@2.1.22/node_modules/@expo/apple-utils/bin.js" "$@"
else
  exec node  "$basedir/../../../../../@expo+apple-utils@2.1.22/node_modules/@expo/apple-utils/bin.js" "$@"
fi
