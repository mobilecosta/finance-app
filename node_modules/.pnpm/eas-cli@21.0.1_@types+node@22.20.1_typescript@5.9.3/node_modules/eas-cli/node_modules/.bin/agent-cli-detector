#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*) basedir=`cygpath -w "$basedir"`;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules/agent-cli-detector/dist/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules/agent-cli-detector/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules/agent-cli-detector/dist/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules/agent-cli-detector/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/agent-cli-detector@0.1.2/node_modules:/home/ubuntu/finance-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../agent-cli-detector@0.1.2/node_modules/agent-cli-detector/dist/cli.js" "$@"
else
  exec node  "$basedir/../../../../../agent-cli-detector@0.1.2/node_modules/agent-cli-detector/dist/cli.js" "$@"
fi
